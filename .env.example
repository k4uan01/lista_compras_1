# URL da API do Supabase self-hosted (Kong), ex: http://10.0.0.17:8000
VITE_SUPABASE_URL=http://10.0.0.17:8000

# Chave anon do seu Supabase (encontre em .env do docker ou no Studio)
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Conexão Postgres via Supavisor (POSTGRES_PASSWORD do .env do servidor)
DATABASE_URL=postgresql://postgres.your-tenant-id:SUA_SENHA@10.0.0.17:5432/postgres?sslmode=disable
